# ============================================================
# RideConnect AI Service — Environment Configuration
# Copy this file to .env and fill in real values.
# ============================================================

# ------------------------------------------------------------------
# Supabase PostgreSQL (shared with Laravel backend)
# ------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# ------------------------------------------------------------------
# API key — all non-health endpoints require header: X-API-Key: <key>
# Generate a strong random value, e.g.: openssl rand -hex 32
# Leave blank to disable auth (development only).
# ------------------------------------------------------------------
API_KEY=your-secret-api-key-here

# ------------------------------------------------------------------
# Model file path (relative to container WORKDIR /app)
# The models/ directory is mounted as a persistent Docker volume.
# ------------------------------------------------------------------
MODEL_PATH=models/price_model.pkl

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
LOG_DIR=logs
LOG_LEVEL=INFO

# ============================================================
# Laravel integration example
# ============================================================
#
# From your Laravel controller / service:
#
#   $response = Http::withHeaders([
#       'X-API-Key' => config('services.ai.key'),   // env('AI_SERVICE_KEY')
#       'Accept'    => 'application/json',
#   ])->post(config('services.ai.url') . '/predict-price', [
#       'distance_km'   => $distanceKm,   // float, computed haversine
#       'demand_level'  => $demandLevel,  // int 1–5
#       'traffic_level' => $trafficLevel, // int 1–5
#       'ride_type'     => $ride->ride_type,  // standard|premium|boda|shared
#   ]);
#
#   $price = $response->json('recommended_price');  // float KES
#
# Add to config/services.php:
#   'ai' => [
#       'url' => env('AI_SERVICE_URL', 'http://rideconnect_ai:8001'),
#       'key' => env('AI_SERVICE_KEY'),
#   ],
#
# Add to Laravel .env:
#   AI_SERVICE_URL=http://rideconnect_ai:8001
#   AI_SERVICE_KEY=your-secret-api-key-here
# ============================================================
