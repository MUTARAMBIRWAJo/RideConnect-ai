# RideConnect AI Service environment variables
# Copy to .env and replace placeholder values.

# Core API
APP_ENV=production
API_KEY=replace-with-strong-random-key
PORT=8001
UVICORN_WORKERS=2

# Postgres
DATABASE_URL=postgresql://postgres:password@db-host:5432/rideconnect?sslmode=require

# Model and logging paths inside container
MODEL_PATH=models/price_model.pkl
LOG_DIR=logs
LOG_LEVEL=INFO

# Redis cache + queue
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_NAME=rideconnect:jobs
REDIS_QUEUE_ENABLED=true

# Cache / worker tuning
PRICE_CACHE_TTL_SECONDS=300
DEMAND_CACHE_TTL_SECONDS=120
JOB_RESULT_TTL_SECONDS=86400
WORKER_POLL_TIMEOUT=5
